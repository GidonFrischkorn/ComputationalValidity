\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comprehensive validity matrix showing correlations between all DMC parameters and behavioral indicators. The heatmap reveals selective validity: most indicators reflect a mixture of multiple processes (process impurity), but RT difference scores achieve relatively selective validity for control-related parameters.}}{19}{figure.caption.14}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comprehensive validity matrix showing correlations between all SSP parameters and behavioral indicators. As with DMC, RT difference scores achieve selective validity for the attention-control parameter (initial attentional noise \(sd_0\)), while other indicators reflect mixtures of multiple processes.}}{21}{figure.caption.15}\protected@file@percent }
