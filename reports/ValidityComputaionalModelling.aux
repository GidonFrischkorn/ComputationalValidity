\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Correlation transfer failure for the M3 complex span model. Each panel plots generating parameter correlations (x-axis) against observed cross-task indicator correlations (y-axis) for different behavioral indicators. The dashed identity line marks perfect transfer. As with DMC and SSP, points consistently fall below the identity line: parameter-level correlations across two complex span tasks transfer only partially to indicator-level correlations, even when the tasks share identical processing architecture.}}{42}{figure.caption.37}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{Figure A3: Model Validation --- Empirical Pattern Alignment for DMC and SSP}{42}{section*.38}\protected@file@percent }
\newlabel{figure-a3-model-validation-empirical-pattern-alignment-for-dmc-and-ssp}{{}{42}{Figure A3: Model Validation --- Empirical Pattern Alignment for DMC and SSP}{section*.38}{}}
\@writefile{toc}{\contentsline {section}{References}{42}{section*.40}\protected@file@percent }
\newlabel{refs}{{}{42}{References}{section*.41}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces \textbf  {Panel A:} Distribution of RT congruency effects (incongruent minus congruent mean RT, in ms) across simulated participants under the DMC (blue) and SSP (red), based on the recovery simulations (\emph  {N} = 100, 100 trials per condition, 250 replications). The grey shaded band indicates the typical empirical range for flanker and Simon tasks (20--100 ms). Both models produce predominantly positive congruency effects within this range, confirming that the simulation parameter space generates behavioral data consistent with empirical conflict-task observations. \textbf  {Panel B:} Population-level delta plots for DMC and SSP, computed from a dedicated simulation (\emph  {N} = 300, 200 trials per condition) using the default parameter ranges. Each point corresponds to one RT quantile bin; lines connect bins from fastest (left) to slowest (right). The DMC (blue) shows the characteristic activation-suppression signature --- an initially small or negative delta at fast responses that increases sharply at slower responses --- while the SSP (red) produces a monotonically increasing delta function reflecting progressive attentional narrowing. Both patterns are hallmarks of empirical conflict-task data and match the distributional profiles described in the original model validation studies (\citeproc {ref-UlrichEtAl2015}{Ulrich et al., 2015}; \citeproc {ref-WhiteEtAl2011}{White et al., 2011}, \citeproc {ref-WhiteEtAl2018}{2018}).}}{43}{figure.caption.39}\protected@file@percent }
\newlabel{fig-modelvalidation}{{14}{43}{\textbf {Panel A:} Distribution of RT congruency effects (incongruent minus congruent mean RT, in ms) across simulated participants under the DMC (blue) and SSP (red), based on the recovery simulations (\emph {N} = 100, 100 trials per condition, 250 replications). The grey shaded band indicates the typical empirical range for flanker and Simon tasks (20--100 ms). Both models produce predominantly positive congruency effects within this range, confirming that the simulation parameter space generates behavioral data consistent with empirical conflict-task observations. \textbf {Panel B:} Population-level delta plots for DMC and SSP, computed from a dedicated simulation (\emph {N} = 300, 200 trials per condition) using the default parameter ranges. Each point corresponds to one RT quantile bin; lines connect bins from fastest (left) to slowest (right). The DMC (blue) shows the characteristic activation-suppression signature --- an initially small or negative delta at fast responses that increases sharply at slower responses --- while the SSP (red) produces a monotonically increasing delta function reflecting progressive attentional narrowing. Both patterns are hallmarks of empirical conflict-task data and match the distributional profiles described in the original model validation studies (\citeproc {ref-UlrichEtAl2015}{Ulrich et al., 2015}; \citeproc {ref-WhiteEtAl2011}{White et al., 2011}, \citeproc {ref-WhiteEtAl2018}{2018})}{figure.caption.39}{}}
